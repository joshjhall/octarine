{
  "name": "Octarine Development",
  "dockerComposeFile": "docker-compose.yml",
  "service": "devcontainer",
  "workspaceFolder": "/workspace/octarine",

  // Use the container's ENTRYPOINT instead of VS Code's default "sleep infinity"
  // This ensures our entrypoint runs to set up Docker socket permissions, etc.
  "overrideCommand": false,

  // Don't use features in VS Code. Rather, use the container features to be consistent across environments.
  // "features": {},

  // Container environment variables
  // "containerEnv": {
  //   "SKIP_CASE_CHECK": "true"  // Suppress case-sensitivity warning if you're aware of limitations
  // },

  // Install development dependencies once when container is created
  "postCreateCommand": "bash /workspace/octarine/.devcontainer/post-create.sh",

  // Configure git, CLI auth, and install git hooks on every start
  "postStartCommand": "bash /workspace/octarine/.devcontainer/post-start.sh",

  "customizations": {
    "vscode": {
      "extensions": [
        // Rust development
        "rust-lang.rust-analyzer",
        "tamasfe.even-better-toml",
        // Linting & formatting
        "redhat.vscode-yaml",
        "biomejs.biome",
        // Database
        "mtxr.sqltools",
        "mtxr.sqltools-driver-pg",
        // Docker & DevOps
        "ms-azuretools.vscode-docker",
        "ms-vscode.makefile-tools",
        // Git
        "donjayamanne.githistory",
        // Editor enhancements
        "usernamehw.errorlens",
        "streetsidesoftware.code-spell-checker",
        "wayou.vscode-todo-highlight",
        // Documentation
        "bierner.markdown-mermaid",
        // AI assistance
        "Anthropic.claude-code"
      ],

      "settings": {
        // Rust settings
        "rust-analyzer.cargo.buildScripts.enable": true,
        "rust-analyzer.checkOnSave": true,
        "rust-analyzer.check.command": "clippy",
        "rust-analyzer.procMacro.enable": true,
        "rust-analyzer.cargo.features": "all",
        "[rust]": {
          "editor.formatOnSave": true,
          "editor.defaultFormatter": "rust-lang.rust-analyzer"
        },

        // YAML settings (Red Hat YAML)
        "[yaml]": {
          "editor.formatOnSave": true,
          "editor.defaultFormatter": "redhat.vscode-yaml"
        },
        "yaml.format.bracketSpacing": false,

        // JSON settings (biome)
        "[json]": {
          "editor.formatOnSave": true,
          "editor.defaultFormatter": "biomejs.biome"
        },
        "[jsonc]": {
          "editor.formatOnSave": true,
          "editor.defaultFormatter": "biomejs.biome"
        },

        // General editor settings
        "editor.formatOnSave": true,

        // Terminal settings
        "terminal.integrated.defaultProfile.linux": "bash",
        "terminal.integrated.profiles.linux": {
          "bash": {
            "path": "/bin/bash",
            "args": ["-l"]
          }
        }
      }
    }
  },

  "remoteUser": "vscode"
}
